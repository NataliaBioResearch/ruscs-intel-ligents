Codi d’ingestió recomanat (ns_acoustic/audio_loader.py)
python
import os
import numpy as np
import pandas as pd

BASE_DIR = os.path.join(
    os.path.dirname(os.path.dirname(__file__)),
    "data",
    "audio_processed"
)

def load_pcm(timestamp):
    path = os.path.join(BASE_DIR, "pcm", f"{timestamp}.npy")
    return np.load(path)

def load_mel(timestamp):
    path = os.path.join(BASE_DIR, "mel", f"{timestamp}.npy")
    return np.load(path)

def load_metadata():
    path = os.path.join(BASE_DIR, "metadata.csv")
    return pd.read_csv(path)
