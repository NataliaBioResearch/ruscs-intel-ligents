Codi d’ingestió recomanat (ns_device/backend_audio.py)
python
import os
import numpy as np

BASE_DIR = os.path.join(
    os.path.dirname(os.path.dirname(__file__)),
    "data",
    "audio_raw"
)

def load_opus(timestamp):
    path = os.path.join(BASE_DIR, "opus", f"{timestamp}.opus")
    if not os.path.exists(path):
        raise FileNotFoundError(f"No s'ha trobat el fitxer: {path}")
    with open(path, "rb") as f:
        return f.read()

def load_raw_i2s(timestamp):
    path = os.path.join(BASE_DIR, "raw_i2s", f"{timestamp}.raw")
    if not os.path.exists(path):
        raise FileNotFoundError(f"No s'ha trobat el fitxer: {path}")
    return np.fromfile(path, dtype=np.float32)
