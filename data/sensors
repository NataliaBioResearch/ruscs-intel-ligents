Codi recomanat per ingestió (ns_device/backend_sensors.py)
python
import pandas as pd
import os

DATA_DIR = os.path.join(
    os.path.dirname(os.path.dirname(__file__)),
    "data",
    "sensors"
)

def load_sensor_data(filename):
    path = os.path.join(DATA_DIR, filename)
    if not os.path.exists(path):
        raise FileNotFoundError(f"No s'ha trobat el fitxer: {path}")
    return pd.read_csv(path)

def load_all_sensors():
    return {
        "weight": load_sensor_data("weight.csv"),
        "temp_internal": load_sensor_data("temperature_internal.csv"),
        "temp_external": load_sensor_data("temperature_external.csv"),
        "humidity": load_sensor_data("humidity.csv"),
        "power": load_sensor_data("power.csv"),
        "activity": load_sensor_data("activity.csv")
    }
Integració amb correlacions (ns_correlations/corr_engine.py)
python
from ns_device.backend_sensors import load_all_sensors

def compute_correlations():
    sensors = load_all_sensors()
    df = sensors["weight"].merge(
        sensors["temp_internal"], on="timestamp"
    ).merge(
        sensors["humidity"], on="timestamp"
    )

    return df.corr()
