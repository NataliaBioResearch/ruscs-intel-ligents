python
import pandas as pd
import os

DATA_DIR = os.path.join(
    os.path.dirname(os.path.dirname(__file__)),
    "data",
    "meteo"
)

def load_meteo_csv(filename):
    path = os.path.join(DATA_DIR, filename)
    if not os.path.exists(path):
        raise FileNotFoundError(f"No s'ha trobat el fitxer: {path}")
    return pd.read_csv(path)

def load_meteo_all():
    return {
        "temp": load_meteo_csv("temperature_external.csv"),
        "humidity": load_meteo_csv("humidity_external.csv"),
        "wind": load_meteo_csv("wind_speed.csv"),
        "rain": load_meteo_csv("rain_mm.csv"),
        "pressure": load_meteo_csv("pressure.csv")
    }
