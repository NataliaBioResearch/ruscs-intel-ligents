def compute_meteo_features(df):
    df["temp_trend"] = df["temp_c"].diff()
    df["humidity_trend"] = df["humidity_pct"].diff()
    df["wind_trend"] = df["wind_ms"].diff()
    df["rain_accum"] = df["rain_mm"].rolling(6).sum()
    return df
